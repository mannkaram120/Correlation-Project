# ─────────────────────────────────────────────────────────────────
# CORR environment variables
# Copy this file to .env.local and fill in your key
# ─────────────────────────────────────────────────────────────────

# Get your free API key at https://twelvedata.com/register
# Free tier: 800 calls/day · 8 calls/min
# CORR uses 1 batch call per refresh → well within free limits
VITE_TWELVEDATA_KEY=your_twelvedata_api_key_here

# FRED API is free with no key required for daily series.
# Optionally add a key for higher rate limits (get one at https://fred.stlouisfed.org/docs/api/api_key.html)
# VITE_FRED_KEY=your_fred_api_key_here
